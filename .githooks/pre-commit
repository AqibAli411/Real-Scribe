#!/usr/bin/env bash
set -euo pipefail

echo "[security] scanning staged changes for secrets..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [[ -z "${STAGED_FILES}" ]]; then
  exit 0
fi

PATTERN='(AKIA[0-9A-Z]{16}|AIza[0-9A-Za-z\-_]{35}|-----BEGIN (RSA|EC|OPENSSH|PRIVATE) KEY-----|password\s*[:=]\s*["'"'"'`][^"'"'"'`]+["'"'"'`]|secret\s*[:=]\s*["'"'"'`][^"'"'"'`]+["'"'"'`]|token\s*[:=]\s*["'"'"'`][^"'"'"'`]+["'"'"'`])'

for file in ${STAGED_FILES}; do
  if [[ ! -f "${file}" ]]; then
    continue
  fi

  if rg -n -i "${PATTERN}" "${file}" >/dev/null 2>&1; then
    echo "[security] potential secret detected in ${file}. Commit blocked."
    echo "Review staged content and move secrets to environment variables."
    exit 1
  fi
done

exit 0
