# Optional: copy to Backend/.env — run-dev.sh loads it. Or use application-local.properties (see example in src/main/resources).
# Your Postgres password must match the server (default "postgres" is often wrong on Ubuntu).
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/realscribe
SPRING_DATASOURCE_USERNAME=aqib-ali
SPRING_DATASOURCE_PASSWORD=
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL_ROOT=INFO
