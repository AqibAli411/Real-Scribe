# Real-Scribe Frontend Environment Variables
# Copy this file to .env and fill in the values

# Backend API URL (used for production builds and `vite preview`, not for `npm run dev`)
# - Dev (`npm run dev`): leave unset — the Vite dev server proxies /api and /ws to localhost:8080
# - Production: https://your-backend.onrender.com
# VITE_API_URL=https://your-api.example.com

# Optional: WebSocket URL override (defaults to VITE_API_URL + /ws)
# VITE_WS_URL=
